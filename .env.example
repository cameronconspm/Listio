# Required for sign-in and cloud data (lists, meals, recipes, etc.).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Password reset: Supabase redirects to this URL after the user taps the email link.
#
# Production (recommended): host web/password-reset-landing.html at a fixed https path, then set:
#   EXPO_PUBLIC_PASSWORD_RESET_WEB_URL=https://thelistioapp.com/auth/reset-password
# Add that SAME https URL to Supabase → Authentication → URL Configuration → Redirect URLs (and keep listio://… below).
#
# If this variable is unset, the app uses listio://auth/reset-password (and Expo dev URL in Expo Go).
#   listio://auth/reset-password
#   exp://127.0.0.1:8081/--/auth/reset-password   (Expo Go; port/host may differ)
#
# EXPO_PUBLIC_PASSWORD_RESET_WEB_URL=

# RevenueCat public SDK key (iOS) — Project settings → API keys. Required on iOS: without it the user stays on
# the subscription gate. Create products in App Store Connect (e.g. listio_premium_monthly, listio_premium_annual)
# and mirror them in RevenueCat with entitlement id matching src/constants/subscription.ts (default: premium).
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# Optional: set to 1 for verbose RevenueCat DEBUG logs in Metro (default is WARN).
# EXPO_PUBLIC_REVENUECAT_VERBOSE_LOGS=1

# Set to 1 at build time to skip the iOS subscription gate (internal / CI only). EAS: profile `internal-no-iap`.
# Do not use for App Store or TestFlight — reviewers must see IAP.
# EXPO_PUBLIC_DISABLE_IOS_SUBSCRIPTION_GATE=1
#
# Internal / TestFlight QA only: show Profile → Demo (Show paywall, load demo data, delete data) and Replay onboarding
# for any signed-in user. Still use the official test email OR set this — both work. Never enable on App Store production.
# EXPO_PUBLIC_ENABLE_QA_SETTINGS_TOOLS=1
#
# iOS Simulator: attach the StoreKit file in Xcode (Scheme → Run → Options → StoreKit Configuration).
# The config plugin `plugins/withListioStorekit.js` wires `storekit/Listio.storekit` for local testing.

# EAS project ID is in app.json (extra.eas.projectId). Override locally with:
# EXPO_PUBLIC_EAS_PROJECT_ID=
# EAS cloud builds: add the same EXPO_PUBLIC_* values under expo.dev → Environment variables (production),
# or run `npm run eas:sync-env` (logged in via eas-cli) to push this .env to EAS production.
#
# CI also runs `npm run verify:eas-production` (ensures production / app-store-review EAS profiles never set
# EXPO_PUBLIC_DISABLE_IOS_SUBSCRIPTION_GATE or EXPO_PUBLIC_ENABLE_QA_SETTINGS_TOOLS) and
# `npm run verify:app-store-legal-urls` (HEADs the privacy, terms, and help URLs — keep in sync with src/constants/legalUrls.ts).

# Supabase Edge Functions `place-search` and `places-nearby` read GOOGLE_PLACES_API_KEY from project secrets (server-side only).
# Enable Geocoding API and Places API (Nearby Search / legacy) on the same GCP project; do not put this key in the Expo app.
#   supabase secrets set GOOGLE_PLACES_API_KEY=your-server-key
# Optional per-user per-minute limits (defaults: 90 place-search, 45 places-nearby):
#   supabase secrets set PLACES_RATE_PLACE_SEARCH_PER_MIN=90
#   supabase secrets set PLACES_RATE_PLACES_NEARBY_PER_MIN=45

# Optional: Your ngrok authtoken for expo start --tunnel when Expo's default fails.
# Get it from https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
