{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "shared/**/*.ts",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions"
  ]
}
