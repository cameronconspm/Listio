{
  "name": "listio",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "npx expo start",
    "start:dev": "npx expo start --dev-client",
    "start:dev:clear": "npx expo start --dev-client --clear",
    "start:tunnel": "npx expo start --tunnel",
    "start:clear": "npx expo start --clear",
    "postinstall": "node scripts/patch-expo-tunnel.js && patch-package",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "ios:open": "open ios/Listio.xcworkspace",
    "ios:run-device": "npx expo run:ios --device",
    "web": "npx expo start --web",
    "eas:ios:dev": "npx eas-cli@latest build --platform ios --profile development",
    "eas:ios": "npx eas-cli@latest build --platform ios --profile production",
    "eas:ios:submit": "npx eas-cli@latest submit --platform ios --latest --profile production",
    "eas:ios:testflight": "npx eas-cli@latest build --platform ios --profile production --auto-submit",
    "eas:ios:app-store-review": "npx eas-cli@latest build --platform ios --profile app-store-review --auto-submit",
    "eas:sync-env": "node scripts/sync-eas-env-from-dotenv.js",
    "tokens:export": "node scripts/export-design-tokens.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "test": "jest",
    "verify:location-backend": "node scripts/verify-location-backend.js",
    "verify:eas-production": "node scripts/verify-eas-production-safety.js",
    "verify:app-store-legal-urls": "node scripts/verify-app-store-legal-urls.js",
    "ci": "npm run typecheck && npm run lint && npm run verify:location-backend && npm run verify:eas-production && npm run verify:app-store-legal-urls && npm test -- --ci"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.11.0",
    "@supabase/supabase-js": "^2.93.2",
    "@tanstack/query-async-storage-persister": "^5.96.2",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-query-persist-client": "^5.96.2",
    "expo": "~54.0.33",
    "expo-blur": "^15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.15.1",
    "react-native-purchases-ui": "^9.15.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "supabase": "^2.72.8",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "react-native-worklets": "0.5.1"
  }
}
